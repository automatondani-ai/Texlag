# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Upstash Redis (REST client) ────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Must be a verified sender address on your Resend domain, e.g. quotes@yourdomain.com
RESEND_FROM_EMAIL=
