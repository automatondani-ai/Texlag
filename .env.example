# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=

# ── Upstash Redis (REST client) ────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Authentication ─────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Required. Verified sender address on your Resend domain, e.g. quotes@yourdomain.com
# Falls back to onboarding@resend.dev when unset (Resend test address — delivers to
# your own account only; not suitable for production use).
RESEND_FROM_EMAIL=
